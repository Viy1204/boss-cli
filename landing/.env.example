# 部署配置示例，复制为 .env.deploy 并填写真实值

# Docker 镜像仓库（如阿里云 ACR）
DOCKER_REGISTRY=registry.cn-shanghai.aliyuncs.com/your-namespace
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# SSH 服务器（与 xhs-cli 同一台）
SSH_HOST=your-server-ip
SSH_USERNAME=root
SSH_PASSWORD=your-ssh-password
# SSH_PORT=22

# 可选覆盖
# DEPLOY_TAG=latest
# DOCKER_IMAGE_NAME=boss-cli-landing
# DEPLOY_CONTAINER_NAME=boss-cli-landing
# DEPLOY_PUBLISH_PORT=38522
# DEPLOY_CONTAINER_TZ=Asia/Shanghai
